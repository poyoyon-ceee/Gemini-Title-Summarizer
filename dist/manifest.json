{
  "manifest_version": 3,
  "name": "Gemini Title Summarizer",
  "version": "1.0",
  "description": "Geminiのチャットタイトルに「要約：」を自動追加するメニューを拡張します。",
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
